{
  "name": "gept-kids-app",
  "version": "0.1.0",
  "private": true,
  "description": "2026 全功能英檢 (小 GEPT / 初級) 全端檢定 App",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "content:phonics": "tsx scripts/run-slicer.ts",
    "content:validate": "tsx scripts/content-validate.ts",
    "content:build": "tsx scripts/content-build.ts",
    "gen:sentences": "tsx scripts/gen-sentences.ts",
    "gen:images": "tsx scripts/gen-images.ts",
    "gen:audio": "tsx scripts/gen-audio.ts",
    "gen:questions": "tsx scripts/gen-questions.ts",
    "csv:words": "tsx scripts/csv-to-words.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^5.22.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.50.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.5.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.5.16",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
