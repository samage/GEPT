# ==========================================
# 環境變數範本（請複製為 .env 並填入真實值；.env 不可進版控）
# ==========================================

# --- 資料庫（Neon / Supabase / 本機 PostgreSQL）---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/gept?schema=public"

# --- Azure 語音服務（Pronunciation Assessment）---
# 從 Azure Portal > Speech 資源取得；免費 F0 層即可
AZURE_SPEECH_KEY=""
AZURE_SPEECH_REGION="eastasia"

# --- 限流（正式環境使用 Upstash Redis；本機留空則自動改用記憶體限流）---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# 每分鐘每使用者/IP 發音評測上限
RATE_LIMIT_PER_MINUTE="20"

# --- 應用設定 ---
# 允許的前端來源（CORS allowlist，逗號分隔），不要使用 *
ALLOWED_ORIGINS="http://localhost:3000"

# ==========================================
# 以下僅供本機「離線內容生成腳本」使用，前端與執行時不需要
# ==========================================
# 生成例句用的 LLM（擇一）
OPENAI_API_KEY=""
# 生成插畫用的生圖模型（擇一）
OPENAI_IMAGE_API_KEY=""
